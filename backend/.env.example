# =========================================
# 🌐 環境設定
# =========================================
# 運行環境：development / test / production
NODE_ENV=development

# =========================================
# 💾 資料庫設定 (MySQL)
# =========================================
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASS=TNAaz.356788

# 🔹 資料庫名稱（各環境可分開設定）
DB_NAME=test
DB_NAME_TEST=test_test
DB_NAME_PROD=test_prod

# =========================================
# 🔐 JWT 驗證設定
# =========================================
JWT_SECRET=supersecretkey
JWT_EXPIRES_IN=7d
JWT_ISSUER=myapp-backend

# =========================================
# 🧰 伺服器設定
# =========================================
PORT=8080
HOST=0.0.0.0

# =========================================
# 🗂️ 上傳 / 檔案相關設定
# =========================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=20MB

# =========================================
# 🧠 OnlyOffice 整合（若未使用可留空）
# =========================================
ONLYOFFICE_JWT_SECRET=onlyoffice-secret
ONLYOFFICE_API_URL=http://localhost:8080/onlyoffice
