# =========================================
# 🌐 環境設定
# =========================================
NODE_ENV=production

# =========================================
# 💾 資料庫設定 (MySQL)
# =========================================
# ⚠️ 建議使用雲端或 Docker 服務名稱，不要用 localhost
DB_HOST=db
DB_PORT=3307
DB_USER=root
DB_PASS=YOUR_SECURE_PASSWORD_HERE
DB_NAME_PROD=test_prod

# =========================================
# 🔐 JWT 驗證設定
# =========================================
# ⚠️ 請使用長且隨機的金鑰，例如透過 `openssl rand -base64 32`
JWT_SECRET=YOUR_LONG_RANDOM_JWT_SECRET
JWT_EXPIRES_IN=7d
JWT_ISSUER=myapp-backend

# =========================================
# 🧰 伺服器設定
# =========================================
PORT=8080
HOST=0.0.0.0

# =========================================
# 🗂️ 上傳 / 檔案相關設定
# =========================================
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=50MB

# =========================================
# 🧠 OnlyOffice 整合（若無整合可留空）
# =========================================
ONLYOFFICE_JWT_SECRET=YOUR_ONLYOFFICE_SECRET
ONLYOFFICE_API_URL=https://your-domain.com/onlyoffice

# =========================================
# 🧾 日誌與錯誤追蹤
# =========================================
LOG_LEVEL=warn
LOG_DIR=/app/logs
ENABLE_STACKTRACE=false

# =========================================
# 📦 版本資訊（可選）
# =========================================
APP_VERSION=1.0.0
APP_BUILD=production
